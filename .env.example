# ══════════════════════════════════════════════════════════════════════════════
# ARIA — Environment Variables
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════════════════════════════

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Create a resource at portal.azure.com → Azure OpenAI → Deploy a model
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-10-21

# Name of your deployed model (set when you create the deployment)
AZURE_REASONING_DEPLOYMENT=your-deployment-name
AZURE_EXTRACTION_DEPLOYMENT=your-deployment-name

# ── Tavily Search (required for web research) ─────────────────────────────────
# Get a free key at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ── SEC EDGAR (no registration needed) ───────────────────────────────────────
# The SEC only requires a User-Agent with contact info. No sign-up.
EDGAR_USER_AGENT=aria-research your@email.com

# ── Checkpoint backend ────────────────────────────────────────────────────────
# "memory" → in-process, lost on restart (fine for dev)
# "postgres" → persists across restarts (for production)
CHECKPOINT_BACKEND=memory
# POSTGRES_URL=postgresql://user:password@host:5432/aria

# ── Output directory ──────────────────────────────────────────────────────────
OUTPUT_DIR=outputs
